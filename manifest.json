{
  "manifest_version": 3,
  "name": "ChessMate",
  "version": "0.4.0",
  "description": "Live Stockfish analysis overlay for chess.com with human-readable labels, offline opening theory (7.6k named positions, depth-5+ continuations), Stockfish move advice in plain English, and Wikipedia/Lichess read-more links.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ChessMate",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.chess.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": [
        "content/board-reader.js",
        "content/analysis-labels.js",
        "content/opening-book.js",
        "content/engine-hints.js",
        "engine/stockfish-worker.js",
        "content/overlay.js",
        "content/content.js"
      ],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "engine/stockfish.js",
        "engine/stockfish.wasm",
        "data/openings.json"
      ],
      "matches": ["https://www.chess.com/*"]
    }
  ]
}
