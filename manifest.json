{
  "manifest_version": 3,
  "name": "LASKER",
  "version": "0.11.4",
  "description": "Unlock free, deep chess analysis with Lasker. Improve your game without limits, because every player deserves a top-tier coach.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "LASKER",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.chess.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.chess.com/*"],
      "js": [
        "content/fair-play.js",
        "content/board-reader.js",
        "content/analysis-labels.js",
        "content/opening-book.js",
        "content/engine-hints.js",
        "content/board-arrows.js",
        "content/move-list-reader.js",
        "engine/stockfish-worker.js",
        "content/analyze-session.js",
        "content/overlay.js",
        "content/content.js"
      ],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "engine/stockfish.js",
        "engine/stockfish.wasm",
        "data/openings.json",
        "data/opening-catalog.json",
        "fonts/SpaceGrotesk-Regular.woff2",
        "fonts/SpaceGrotesk-Medium.woff2",
        "fonts/SpaceGrotesk-SemiBold.woff2",
        "fonts/SpaceGrotesk-Bold.woff2"
      ],
      "matches": ["https://www.chess.com/*"]
    }
  ]
}
